rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from the developer/admin?
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "hlongwasphephelo40@gmail.com";
    }

    // Users: owner can read/write their own data; admin can read all and delete any
    match /users/{userId} {
      allow read:   if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write:  if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Leaderboard: any authenticated user can read; only owner can write their own entry; admin can delete any
    match /leaderboard/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId
                   && request.resource.data.streak is int
                   && request.resource.data.streak >= 0
                   && request.resource.data.displayName is string
                   && request.resource.data.displayName.size() <= 20;
      allow delete: if isAdmin();
    }

    // Reports: any authenticated user can submit; admin can read/update/delete
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Broadcasts: admin can create/read/delete; any authenticated user can read active broadcasts
    match /broadcasts/{broadcastId} {
      allow read:   if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Broadcast Responses: any authenticated user can submit; admin can read/delete
    match /broadcast_responses/{responseId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
