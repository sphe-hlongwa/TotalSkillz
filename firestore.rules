rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "hlongwasphephelo40@gmail.com" || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin'
        )
      );
    }

    // Helper: validate fields not modified
    function unchanged(key) {
      return !(key in request.resource.data) || request.resource.data[key] == resource.data[key];
    }

    // Helper: validate string length
    function isValidString(text, max_len) {
      return text is string && text.size() <= max_len;
    }

    // Users: owner can read/write their own data; admin can read all and delete any
    match /users/{userId} {
      allow read:   if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
                      isAdmin() || (
                        request.auth.uid == userId && 
                        unchanged('role') && 
                        unchanged('xp') && 
                        unchanged('streak')
                      )
                    );
      allow delete: if isAdmin();
    }

    // Leaderboard: any authenticated user can read; only owner can write their own entry; admin can delete any
    match /leaderboard/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId
                   && request.resource.data.streak is int
                   && request.resource.data.streak >= 0
                   && isValidString(request.resource.data.displayName, 25);
      allow delete: if isAdmin();
    }

    // Reports: any authenticated user can submit; admin can read/update/delete
    match /reports/{reportId} {
      allow create: if request.auth != null 
                    && isValidString(request.resource.data.comment, 1000)
                    && isValidString(request.resource.data.module, 50);
      allow read, update, delete: if isAdmin();
    }

    // Broadcasts: admin can create/read/delete; any authenticated user can read active broadcasts
    match /broadcasts/{broadcastId} {
      allow read:   if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Broadcast Responses: any authenticated user can submit; admin can read/delete
    match /broadcast_responses/{responseId} {
      allow create: if request.auth != null
                    && isValidString(request.resource.data.message, 500);
      allow read, delete: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
